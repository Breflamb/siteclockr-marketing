# Copy to .env.local for local dev, or export before `npm run build` for production.
# Web3Forms: https://web3forms.com (free tier includes honeypot spam filtering)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Cloudflare Turnstile site key (public). Add the matching secret in Web3Forms dashboard (Pro).
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
